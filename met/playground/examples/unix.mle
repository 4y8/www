--                                                 then (su Alice; ritchie!)
--                                                 else (su Bob; hamlet!) } } } }

eff interrupt = interrupt : unit => unit

val interrupt : [interrupt](unit -> unit)
let interrupt! = do interrupt ()

-- no mention of interrupt here
type pstate a = Done of a | Paused of { pstate a }

val reify_process : forall [a] . [](<interrupt>{a} -> pstate a)
let reify_process m =
  handle m! with
  | return res => Done (res)
  | interrupt _ k => Paused (k)
  end

val example4 : forall [a] . [](<interrupt, fork>{a} -> list (<fork>(pstate a)))
let example4 m =
  nondet { reify_process m }

val schedule : forall [a] . [](list (<fork>(pstate a)) -> list a -> list a)
let schedule ps done =
  match ps with
  | Nil -> done
  | Cons (Done (res), ps') -> schedule ps' (Cons (res, done))
  | Cons (Paused (m), ps') -> schedule (append ps' (nondet m)) done
  end

val timeshare : forall [a] . [](<fork, interrupt>{a} -> list a)
let timeshare m =
  schedule (Cons (Paused ({ reify_process m }), Nil)) Nil

val interrupt_write : forall [a] . [interrupt, bio](<bio>{a} -> a)
let interrupt_write m =
  handle m! with
  | return res => res
  | write x k => interrupt!; k (do write x)
  end

