eff state [a] = get : unit => a | put : a => unit

val get : forall [a] . [state a](unit -> a)
let get! = do get ()

val put : forall [a] . [state a](a -> unit)
let put st = do put st

val run_state : forall [a] [b] . [] (b -> <state b>{a} -> a * b)
let run_state st0 m =
  let run = handle m! with
    | return res => fun st -> (res, st)
    | get _ k => fun st -> k st st
    | put st' k => fun st -> k () st'
    end
  in run st0
